cat << 'EOF' > usuario.sh
#!/bin/bash
# 1. Crear el grupo secundario exigido
sudo groupadd p1c1_2026_g1 2>/dev/null

# 2. Crear el usuario asignando su directorio HOME de forma explícita
sudo useradd -m -s /bin/bash -G p1c1_2026_g1 p1c1_2026_u1

# 3. Inyectar la clave mediante chpasswd según la metodología de clase
echo "p1c1_2026_u1:clave1" | sudo chpasswd
EOF

cat << 'EOF' > Punto_B.sh
# Dar permisos de ejecución y correr el script de usuario
chmod +x usuario.sh
./usuario.sh

# Ajustar dueños de forma recursiva (Dueño: p1c1_2026_u1, Grupo: p1c1_2026_g1)
sudo chown -R p1c1_2026_u1:p1c1_2026_g1 /datos/

# Aplicar permisos octales (Dueño=rwx(7), Grupo=r-x(5), Otros=---(0)) -> 750
sudo chmod -R 750 /datos/

# Generar archivo de validación ejecutando comandos como el nuevo usuario
sudo su -c "whoami > /datos/validar1.txt" p1c1_2026_u1
EOF

git add usuario.sh Punto_B.sh
git commit -m "FIX: Ajuste estricto de metodología Punto B"
git push origin main
cat << 'EOF' > Punto_C.sh
# 1. Crear el grupo común y el segundo usuario con su clave
sudo groupadd p1c1_2026_Todos 2>/dev/null
sudo useradd -m -s /bin/bash -g p1c1_2026_Todos p1c1_2026_u2
echo "p1c1_2026_u2:clave1" | sudo chpasswd

# 2. Agregar al primer usuario al grupo común de forma secundaria
sudo usermod -aG p1c1_2026_Todos p1c1_2026_u1

# 3. Modificar grupo propietario de /datos y dar permisos de escritura al grupo
sudo chown -R :p1c1_2026_Todos /datos/
sudo chmod -R 770 /datos/

# 4. Ajuste para conocer existencia de archivos pero sin ver contenido
sudo chmod o+rx /datos/
sudo chmod o-rwx /datos/validar1.txt

# 5. Agregar la salida del comando id con el usuario u2
sudo su -c "id >> /datos/validar1.txt" p1c1_2026_u2
EOF

git add Punto_C.sh
git commit -m "ADD: Solución Punto C completada"
git push origin main
cat << 'EOF' > Punto_C.sh
# 1. Crear el grupo principal para u2
sudo groupadd p1c1_2026_Todos 2>/dev/null

# 2. Crear al usuario p1c1_2026_u2 asignando su grupo principal
sudo useradd -m -s /bin/bash -g p1c1_2026_Todos p1c1_2026_u2

# 3. Asignar la misma clave que u1 (clave1)
echo "p1c1_2026_u2:clave1" | sudo chpasswd

# 4. Agregar al usuario p1c1_2026_u1 en el grupo p1c1_2026_Todos (secundario)
sudo usermod -aG p1c1_2026_Todos p1c1_2026_u1

# 5. Modificar el grupo propietario de /datos y todo su contenido
sudo chown -R :p1c1_2026_Todos /datos/

# 6. Dar permisos de escritura al grupo (Manteniendo rwx para dueño y grupo, nada para otros)
sudo chmod -R 770 /datos/



cat << 'EOF' > Punto_C.sh
# 1. Crear el grupo principal para u2
sudo groupadd p1c1_2026_Todos 2>/dev/null

# 2. Crear al usuario p1c1_2026_u2 asignando su grupo principal
sudo useradd -m -s /bin/bash -g p1c1_2026_Todos p1c1_2026_u2

# 3. Asignar la misma clave que u1 (clave1)
echo "p1c1_2026_u2:clave1" | sudo chpasswd

# 4. Agregar al usuario p1c1_2026_u1 en el grupo p1c1_2026_Todos (secundario)
sudo usermod -aG p1c1_2026_Todos p1c1_2026_u1

# 5. Modificar el grupo propietario de /datos y todo su contenido
sudo chown -R :p1c1_2026_Todos /datos/

# 6. Dar permisos de escritura al grupo (Manteniendo rwx para dueño y grupo, nada para otros)
sudo chmod -R 770 /datos/

# 7. Modificación para que tu usuario conozca la existencia pero no vea contenido
# Se asigna solo permiso de ejecución (x) a otros en la carpeta datos
sudo chmod o+x /datos/
sudo chmod o-r /datos/

# 8. Agregar al archivo la salida del comando id ejecutada con el usuario u2
sudo su -c "id >> /datos/validar1.txt" p1c1_2026_u2
EOF

